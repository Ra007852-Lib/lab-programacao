Exercício 01
def status_aluno(media):
    if media > 6:
        return "Aprovado"
    elif media >= 4:
        return "Verificação Suplementar"
    else:
        return "Reprovado"
media = float(input("Digite a média do aluno: "))
print("Status:", status_aluno(media))

Exercício 02
def celsius_para_fahrenheit(celsius):
    fahrenheit = celsius * 1.8 + 32
    return fahrenheit
temperatura = float(input("Digite a temperatura em Celsius: "))
resultado = celsius_para_fahrenheit(temperatura)
print("Temperatura em Fahrenheit:", resultado)

Exercício 03
def permitir_acesso(ano_nascimento):
    idade = 2026 - ano_nascimento
    if idade >= 18:
        return True
    else:
        return False
    
print("--- VALIDADOR DE SISTEMA ---")
ano = int(input("Em qual ano você nasceu? "))

if permitir_acesso(ano):
    print("Acesso liberado ao sistema. Bem-vindo!")
else:
    print("Acesso bloqueado. Apenas para maiores de 18 anos")

